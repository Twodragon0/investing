{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "variant": "medium",
  "small_model": "google/antigravity-gemini-3-flash",
  "small_model_variant": "medium",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "task": "deny",
    "todoread": "allow",
    "todowrite": "allow",
    "bash": {
      "*": "allow",
      "rm *": "deny",
      "sudo *": "deny"
    }
  },
  "tools": {
    "task": false,
    "read": true,
    "glob": true,
    "grep": true,
    "list": true,
    "edit": true,
    "bash": true,
    "todowrite": true,
    "todoread": true
  }
}
