---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0"
  xmlns:atom="http://www.w3.org/2005/Atom"
  xmlns:media="http://search.yahoo.com/mrss/"
  xmlns:dc="http://purl.org/dc/elements/1.1/"
  xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <description>{{ site.description | xml_escape }}</description>
    <language>{{ site.lang | default: "ko" }}</language>
    <managingEditor>{{ site.author.name | xml_escape }}</managingEditor>
    <webMaster>{{ site.author.name | xml_escape }}</webMaster>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    <atom:link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/rss+xml"/>
    {% if site.og_image %}
    <image>
      <url>{{ site.og_image | absolute_url }}</url>
      <title>{{ site.title | xml_escape }}</title>
      <link>{{ site.url }}{{ site.baseurl }}/</link>
      <width>144</width>
      <height>144</height>
    </image>
    {% endif %}
    {% for post in site.posts limit: 30 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ site.url }}{{ site.baseurl }}{{ post.url }}</link>
      <description>{{ post.excerpt | default: post.description | default: post.content | strip_html | strip_newlines | normalize_whitespace | xml_escape | truncate: 500 }}</description>
      <content:encoded><![CDATA[{{ post.content }}]]></content:encoded>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <guid isPermaLink="true">{{ site.url }}{{ site.baseurl }}{{ post.url }}</guid>
      <dc:creator>{{ site.author.name | xml_escape }}</dc:creator>
      {% assign post_categories = post.categories | default: empty %}
      {% for cat in post_categories %}
      <category>{{ cat | xml_escape }}</category>
      {% endfor %}
      {% if post.tags %}
      {% for tag in post.tags %}
      <category>{{ tag | xml_escape }}</category>
      {% endfor %}
      {% endif %}
      {% if post.image %}
      <media:content url="{{ post.image | absolute_url }}" medium="image" type="image/png" width="1200" height="630"/>
      <media:thumbnail url="{{ post.image | absolute_url }}" width="1200" height="630"/>
      <enclosure url="{{ post.image | absolute_url }}" type="image/png" length="0"/>
      {% elsif site.og_image %}
      <media:content url="{{ site.og_image | absolute_url }}" medium="image" type="image/png" width="1200" height="630"/>
      <media:thumbnail url="{{ site.og_image | absolute_url }}" width="1200" height="630"/>
      <enclosure url="{{ site.og_image | absolute_url }}" type="image/png" length="0"/>
      {% endif %}
    </item>
    {% endfor %}
  </channel>
</rss>
